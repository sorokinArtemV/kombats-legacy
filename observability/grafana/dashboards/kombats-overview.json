    {
      "type": "timeseries",
      "title": "CPU utilization per service",
      "description": "Computed: rate(process.cpu.time_total) / process.cpu.count. The Process instrumentation does not emit process.cpu.utilization directly as of OpenTelemetry.Instrumentation.Process 1.10.0-beta.1.",
      "datasource": { "type": "prometheus", "uid": "kombats-prometheus" },
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 7 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(process_cpu_time_seconds_total[1m])) / sum by (service) (process_cpu_count)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
