{
  "realm": "kombats",
  "displayName": "KOMBATS",
  "displayNameHtml": "<span class=\"kc-brand-title\">KOMBATS</span><span class=\"kc-brand-tagline\">Turn-based arena combat</span>",
  "loginTheme": "kombats",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 3600,
  "ssoSessionIdleTimeout": 36000,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 2592000,
  "ssoSessionMaxLifespanRememberMe": 2592000,
  "defaultSignatureAlgorithm": "RS256",
  "clients": [
    {
      "clientId": "account",
      "name": "${client_account}",
      "rootUrl": "${authBaseUrl}",
      "baseUrl": "/realms/kombats/account/",
      "enabled": true,
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "/realms/kombats/account/*"
      ],
      "webOrigins": [
        "+"
      ],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "kombats-web",
      "name": "Kombats Web Client",
      "description": "Public OIDC client for the Kombats React/Vite SPA. Uses Authorization Code + PKCE.",
      "rootUrl": "http://localhost:5173",
      "baseUrl": "/",
      "enabled": true,
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5000",
        "http://localhost:3000"
      ],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:5000/*##http://localhost:5173/*",
        "pkce.code.challenge.method": "S256"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "kombats-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "kombats-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "artem",
      "enabled": true,
      "emailVerified": true,
      "email": "artem@kombats.local",
      "firstName": "Artem",
      "lastName": "Dev",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ]
    },
    {
      "username": "polina",
      "enabled": true,
      "emailVerified": true,
      "email": "polina@kombats.local",
      "firstName": "Polina",
      "lastName": "Dev",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ]
    },
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@kombats.local",
      "firstName": "Alice",
      "lastName": "Dev",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ]
    },
    {
      "username": "jun",
      "enabled": true,
      "emailVerified": true,
      "email": "jun@kombats.local",
      "firstName": "Jun",
      "lastName": "Dev",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ]
    }
  ]
}
