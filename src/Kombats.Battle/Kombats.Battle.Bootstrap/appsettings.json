{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=kombats;Username=postgres;Password=postgres;Maximum Pool Size=20;Minimum Pool Size=5;Connection Idle Lifetime=300",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/kombats",
    "Audience": "kombats-api"
  },
  "Messaging": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    },
    "Topology": {
      "EndpointPrefix": "battle",
      "EntityNamePrefix": "combats",
      "UseKebabCase": true,
      "EntityNameMappings": {
        "CreateBattle": "battle.create-battle",
        "BattleCreated": "battle.battle-created",
        "BattleCompleted": "battle.battle-completed"
      }
    }
  },
  "Battle": {
    "Redis": {
      "ActionTtl": "12:00:00",
      "StateTtlAfterEnd": "01:00:00"
    },
    "Rulesets": {
      "CurrentVersion": 1,
      "Versions": {
        "1": {
          "TurnSeconds": 30,
          "NoActionLimit": 10,
          "CombatBalance": {
            "Hp": {
              "BaseHp": 0,
              "HpPerEnd": 6
            },
            "Damage": {
              "BaseWeaponDamage": 0,
              "DamagePerStr": 1.0,
              "DamagePerAgi": 0,
              "DamagePerInt": 0,
              "SpreadMin": 0.9,
              "SpreadMax": 0.95
            },
            "Mf": {
              "MfPerAgi": 5,
              "MfPerInt": 5
            },
            "DodgeChance": {
              "Base": 0.05,
              "Min": 0.02,
              "Max": 0.35,
              "Scale": 1.0,
              "KBase": 50
            },
            "CritChance": {
              "Base": 0.05,
              "Min": 0.01,
              "Max": 0.30,
              "Scale": 1.0,
              "KBase": 60
            },
            "CritEffect": {
              "Mode": "BypassBlock",
              "Multiplier": 2,
              "HybridBlockMultiplier": 0.5
            }
          }
        }
      }
    },
    "RecoveryWorker": {
      "ScanIntervalMs": 30000,
      "StaleBattleThresholdSeconds": 600,
      "BatchSize": 50
    },
    "TurnDeadlineWorker": {
      "BatchSize": 50,
      "IdleDelayMinMs": 200,
      "IdleDelayMaxMs": 1000,
      "BacklogDelayMs": 30,
      "MaxBackoffSteps": 3,
      "ErrorDelayMs": 200
    }
  },
  "BattleRewards": {
    "_comment": "MUST stay in sync with WinnerXp/LoserXp constants in Players' HandleBattleCompletedCommand. These values are surfaced on the BattleEnded SignalR payload so the result screen can render the XP row immediately; Players is the source of truth for what is actually awarded. Future cleanup: extract to shared rewards config service.",
    "WinXp": 10,
    "LossXp": 5
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Exceptions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithExceptionDetails"
    ]
  }
}
