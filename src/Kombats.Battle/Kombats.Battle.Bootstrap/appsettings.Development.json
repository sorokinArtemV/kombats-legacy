{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317",
    "MetricExportIntervalMs": 5000
  }
}
