{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=kombats;Username=postgres;Password=postgres;Maximum Pool Size=20;Minimum Pool Size=5;Connection Idle Lifetime=300",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Players": {
    "BaseUrl": "http://localhost:5001"
  },
  "Messaging": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    },
    "Topology": {
      "EndpointPrefix": "chat",
      "EntityNamePrefix": "combats",
      "UseKebabCase": true,
      "EntityNameMappings": {
        "PlayerCombatProfileChanged": "combats.player-combat-profile-changed"
      }
    }
  },
  "Chat": {
    "Retention": {
      "ScanIntervalSeconds": 3600,
      "MessageTtlHours": 24,
      "BatchSize": 1000,
      "MaxBatchesPerPass": 100
    },
    "PresenceSweep": {
      "ScanIntervalSeconds": 60,
      "StaleAfterSeconds": 90
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/kombats",
    "Audience": "kombats-api"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
