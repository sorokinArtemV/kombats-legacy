# Keycloak realm authority (issuer URL).
VITE_KEYCLOAK_AUTHORITY=
# Keycloak OIDC client ID for the web app.
VITE_KEYCLOAK_CLIENT_ID=
# Base URL of the BFF service (no trailing slash; one is stripped at runtime).
VITE_BFF_BASE_URL=
# Enable per-match arena theming (4 arenas: palace-roof, blood-moon,
# desert, bamboo). When false, the default Palace Roof palette is
# used everywhere. Default: false in production, true in local dev.
VITE_ENABLE_ARENA_THEMES=true
