# Runtime URLs (Keycloak authority, BFF base URL, OIDC client ID) are loaded
# from /config.json at startup, NOT from VITE_* env vars. See public/config.json
# for the local-dev defaults and scripts/deploy-stack.ps1 for prod generation.
#
# Enable per-match arena theming (4 arenas: palace-roof, blood-moon,
# desert, bamboo). When false, the default Palace Roof palette is
# used everywhere. Default: true.
VITE_ENABLE_ARENA_THEMES=true
