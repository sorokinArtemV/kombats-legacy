{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=kombats;Username=postgres;Password=postgres;Maximum Pool Size=20;Minimum Pool Size=5;Connection Idle Lifetime=300",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/kombats",
    "Audience": "kombats-api"
  },
  "Matchmaking": {
    "Redis": {
      "DatabaseIndex": 1,
      "StatusTtlSeconds": 1800,
      "CancelTtlSeconds": 600
    },
    "Worker": {
      "TickDelayMs": 100
    },
    "TimeoutWorker": {
      "ScanIntervalMs": 5000,
      "TimeoutSeconds": 60,
      "BattleCreatedTimeoutSeconds": 600
    },
    "QueuePresence": {
      "PresenceTtlSeconds": 15,
      "StaleAfterSeconds": 15,
      "SweepIntervalSeconds": 20
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    },
    "Topology": {
      "EndpointPrefix": "matchmaking",
      "EntityNamePrefix": "combats",
      "UseKebabCase": true,
      "EntityNameMappings": {
        "PlayerCombatProfileChanged": "combats.player-combat-profile-changed",
        "CreateBattle": "battle.create-battle",
        "BattleCreated": "battle.battle-created",
        "BattleCompleted": "battle.battle-completed"
      }
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
